# 数据库 (PostgreSQL) - 与 nova-space 共用同一数据库
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=nova_space

# JWT
JWT_SECRET=nova-space-secret-key-2024
JWT_EXPIRES_IN=7d

# 服务端口 (避免与 nova-space 的 3001 冲突)
PORT=3002

# 前端地址
FRONTEND_URL=http://localhost:5180

# 环境
NODE_ENV=development