# ==================== 数据库配置 ====================
DB_PASSWORD=your_db_password

# ==================== JWT 配置 ====================
JWT_SECRET=your_jwt_secret_key_here

# ==================== SMTP 邮件配置 ====================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@nova-space.com

# ==================== Space-Track API ====================
# 注册地址: https://www.space-track.org
SPACE_TRACK_USERNAME=your_space_track_username
SPACE_TRACK_PASSWORD=your_space_track_password

# ==================== ESA DISCOS API ====================
# 申请地址: https://discosweb.esoc.esa.int
ESA_DISCOS_API_TOKEN=your_esa_discos_token

# ==================== KeepTrack API ====================
# 申请地址: https://keeptrack.space
KEEPTRACK_API_KEY=your_keeptrack_api_key

# ==================== MinIO 配置 ====================
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123456
MINIO_BUCKET=nova-space

# ==================== 开发配置 ====================
# 是否使用模拟数据（仅开发测试用，生产环境请删除或设为 false）
# USE_MOCK_DATA=false