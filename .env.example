# Docker Compose 环境变量配置
# 复制此文件为 .env 并填入实际值
#
# 注意：此文件用于 Docker 部署，与 backend-nest/.env (本地开发) 是分开的
# Docker 环境中 DB_HOST 固定为 nova-postgres (通过 extra_hosts 指向宿主机)

# 数据库密码
DB_PASSWORD=your_database_password

# JWT 密钥 (建议使用 openssl rand -base64 32 生成)
JWT_SECRET=your_jwt_secret_key

# Space-Track API (用于获取完整卫星元数据)
# 注册地址: https://www.space-track.org
SPACE_TRACK_USERNAME=your_username_here
SPACE_TRACK_PASSWORD=your_password_here